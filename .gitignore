# Virtual environment
.venv/
venv/
env/

# Python caches / build
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/

# Generated route outputs (maps + GPX written by `plan`)
route*.png
route*.gpx

